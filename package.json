{
  "name": "documents-bundle",
  "version": "1.0.0",
  "description": "An Obsidian plugin for self-contained Markdown document bundles.",
  "main": "main.js",
  "scripts": {
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mts production",
    "dev": "node esbuild.config.mts",
    "lint": "eslint src package.json",
    "package:release": "node scripts/package-release.mts",
    "prepare:test-vault": "node scripts/prepare-test-vault.mts",
    "smoke:obsidian": "npm run build && npm run prepare:test-vault && node scripts/obsidian-smoke-test.mts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -noEmit -skipLibCheck",
    "validate:mobile-safety": "npm run build && node scripts/validate-mobile-safety.mts",
    "validate:release": "npm run build && node scripts/validate-release.mts",
    "verify": "npm run lint && npm test && npm run smoke:obsidian && npm run validate:release && npm run validate:mobile-safety && npm audit --audit-level=high && npm run package:release"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/keqing996/ob-plugin-document-bundle.git"
  },
  "bugs": {
    "url": "https://github.com/keqing996/ob-plugin-document-bundle/issues"
  },
  "homepage": "https://github.com/keqing996/ob-plugin-document-bundle#readme",
  "keywords": [
    "obsidian",
    "plugin",
    "documents",
    "bundle",
    "attachments"
  ],
  "author": "kq996",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@typescript-eslint/parser": "^8.61.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "eslint-plugin-obsidianmd": "^0.3.0",
    "obsidian": "^1.8.7",
    "tslib": "^2.8.1",
    "typescript": "^5.8.3",
    "vitest": "^4.1.9"
  }
}
